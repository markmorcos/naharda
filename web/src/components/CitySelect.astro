---
interface City {
  slug: string;
  name: string;
}
interface Props {
  cities: City[];
  current: string;
  base: string; // path prefix, e.g. "/weather/"
}
const { cities, current, base } = Astro.props;
---

<label class="muted" style="display:inline-flex;gap:.5em;align-items:center;font-size:var(--step--1)">
  City
  <select
    onchange={`location.href='${base}'+this.value`}
    style="font:inherit;padding:.4em .6em;border-radius:8px;border:1px solid var(--border);background:var(--canvas);color:var(--ink)"
  >
    {
      cities.map((c) => (
        <option value={c.slug} selected={c.slug === current}>
          {c.name}
        </option>
      ))
    }
  </select>
</label>
