---
interface Props {
  method?: string;
  path: string;
  desc: string;
  curl: string;
  sample: string;
}
const { method = "GET", path, desc, curl, sample } = Astro.props;
---

<section style="margin:var(--sp-3) 0;padding-top:var(--sp-3);border-top:1px solid var(--border)">
  <h3 class="num" style="font-size:var(--step-1);display:flex;gap:.5em;align-items:center;flex-wrap:wrap">
    <span class="tag" style="color:var(--accent);border-color:var(--accent)">{method}</span>
    {path}
  </h3>
  <p class="muted">{desc}</p>
  <pre class="card num" style="overflow:auto"><code>{curl}</code></pre>
  <details>
    <summary class="muted" style="cursor:pointer;font-size:var(--step--1)">Sample response</summary>
    <pre class="card num" style="overflow:auto;margin-top:var(--sp-1)"><code>{sample}</code></pre>
  </details>
</section>
