---
import Base from "../layouts/Base.astro";
import EmailCapture from "./EmailCapture.astro";
import Sparkline from "./Sparkline.astro";
import {
  getFX,
  getGold,
  getFXHistory,
  getGoldHistory,
} from "../lib/api";
import { intentBySlug } from "../lib/intents";

interface Props {
  slug: string;
  lang?: "en" | "ar";
}
const { slug, lang = "en" } = Astro.props;
const intent = intentBySlug(slug);
if (!intent) throw new Error(`Unknown intent slug: ${slug}`);
const isAr = lang === "ar";
const t = isAr ? intent.ar : intent.en;
const site = "https://naharda.com";
const enPath = `/en/${intent.slug}`;
const arPath = `/ar/${intent.slug}`;
const canonicalPath = isAr ? arPath : enPath;

// --- Live value + 30-day series ---------------------------------------------
let value: number | null = null;
let rangeLabel: string | null = null; // parallel only
let unit = "EGP";
let series: number[] = [];
let updated = "unavailable";
let dataProvider = "Naharda";

try {
  if (intent.kind === "gold") {
    const g = await getGold();
    value =
      g?.data?.world_derived?.find((x: any) => x.karat === intent.karat)
        ?.value_egp ?? null;
    unit = "EGP/g";
    updated = g?.meta?.cached_at ? new Date(g.meta.cached_at).toUTCString() : updated;
    const h = await getGoldHistory(intent.karat!);
    series = (h?.data?.history ?? []).map((r: any) => r.value_egp).reverse();
  } else {
    const fx = await getFX();
    updated = fx?.meta?.cached_at ? new Date(fx.meta.cached_at).toUTCString() : updated;
    if (intent.kind === "parallel") {
      const p = fx?.data?.parallel;
      if (p && typeof p.avg === "number" && p.n > 0) {
        value = p.avg;
        rangeLabel = `${p.min}–${p.max} (${p.n})`;
      }
    } else {
      value = fx?.data?.official?.[intent.quote!] ?? null;
    }
    const h = await getFXHistory(intent.quote!);
    series = (h?.data?.history ?? []).map((r: any) => r.value).reverse();
  }
} catch {
  // Live data temporarily unavailable — the page still renders with "—".
}

const display = value != null ? value.toFixed(2) : "—";

// --- Structured data: FAQPage + Dataset + BreadcrumbList --------------------
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: t.faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    name: t.datasetName,
    description: t.description,
    creator: { "@type": "Organization", name: "Naharda", url: site },
    license: `${site}/docs`,
    isAccessibleForFree: true,
    temporalCoverage: "P30D",
    distribution: {
      "@type": "DataDownload",
      encodingFormat: "application/json",
      contentUrl: "https://api.naharda.com/v1/" + (intent.kind === "gold" ? "gold" : "fx"),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: isAr ? "الرئيسية" : "Home", item: site + (isAr ? "/ar" : "/en") },
      { "@type": "ListItem", position: 2, name: t.crumb, item: site + canonicalPath },
    ],
  },
];

const apiCurl =
  intent.kind === "gold"
    ? "curl https://api.naharda.com/v1/gold"
    : "curl https://api.naharda.com/v1/fx";
const apiLabel = isAr ? "هاتها عبر API" : "Get it via API";
const trendLabel = isAr ? "آخر 30 يوم" : "Last 30 days";
const homeHref = isAr ? "/ar" : "/en";
const homeLabel = isAr ? "الرئيسية" : "Home";
---

<Base
  title={t.title}
  description={t.description}
  lang={lang}
  dir={isAr ? "rtl" : "ltr"}
  canonicalPath={canonicalPath}
  enPath={enPath}
  arPath={arPath}
  jsonLd={jsonLd}
  ogImage={`${site}/og/${intent.slug}.png${isAr ? "?lang=ar" : ""}`}
>
  <article style="padding:var(--sp-3) 0">
    <nav class="muted" style="font-size:var(--step--1)" aria-label="Breadcrumb">
      <a href={homeHref}>{homeLabel}</a> › <span>{t.crumb}</span>
    </nav>

    <h1 style="font-size:var(--step-3)">{t.h1}</h1>
    <p class="num delta-up" style="font-size:var(--hero);line-height:1;margin:.1em 0">
      {display} <span class="muted" style="font-size:var(--step-1)">{unit}</span>
    </p>
    <p class="muted">{t.sub}{rangeLabel ? ` · ${rangeLabel}` : ""} · {isAr ? "تحديث" : "updated"} {updated}</p>

    {
      series.length >= 2 && (
        <section style="margin-top:var(--sp-3)">
          <div class="muted" style="font-size:var(--step--1);margin-bottom:.3em">{trendLabel}</div>
          <Sparkline points={series} label={t.datasetName} />
        </section>
      )
    }

    <h2 style="font-size:var(--step-1);margin-top:var(--sp-4)">{t.explainerH2}</h2>
    <p>{t.explainer}</p>

    <h2 style="font-size:var(--step-1);margin-top:var(--sp-4)">{apiLabel}</h2>
    <pre class="card num" style="overflow:auto"><code>{apiCurl}</code></pre>

    <div style="margin-top:var(--sp-4)"><EmailCapture lang={lang} /></div>
  </article>
</Base>
