---
import Base from "../../layouts/Base.astro";
import RateCard from "../../components/RateCard.astro";
import EmailCapture from "../../components/EmailCapture.astro";
import StatsStrip from "../../components/StatsStrip.astro";
import {
  API_PUBLIC_BASE,
  getFX,
  getGold,
  getFuel,
  getWeather,
  getPrayer,
  getCalendar,
} from "../../lib/api";

const [fx, gold, fuel, weather, prayer, cal] = await Promise.all([
  getFX(),
  getGold(),
  getFuel(),
  getWeather(),
  getPrayer(),
  getCalendar(),
]);

const usd = fx?.data?.official?.usd ?? null;
const parallel = fx?.data?.parallel;
const hasParallel = !!(parallel && typeof parallel.avg === "number" && parallel.n > 0);
const parallelRange = hasParallel ? `${parallel.min}–${parallel.max}` : null;
const gold21 =
  gold?.data?.world_derived?.find((g: any) => g.karat === 21)?.value_egp ?? null;
const gas92 =
  fuel?.data?.find((f: any) => f.product === "gasoline-92")?.price_egp ?? null;
const temp = weather?.data?.weather?.temperature_c ?? null;
const fajr = prayer?.data?.prayer_times?.timings?.Fajr ?? null;
const hijri = cal?.data?.hijri ?? null;
const updated = fx?.meta?.cached_at
  ? new Intl.DateTimeFormat("ar-EG-u-nu-latn", {
      day: "numeric",
      month: "long",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "Africa/Cairo",
    }).format(new Date(fx.meta.cached_at))
  : "غير متاح";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Naharda",
  url: "https://naharda.com/ar",
};
---

<Base
  title="الدولار بكام النهاردة؟ — أسعار مصر دلوقتي | Naharda"
  description="كل اللي بيحصل في مصر النهاردة في مكان واحد: الدولار بكام، سعر الذهب، البنزين، مواقيت الصلاة، والطقس — مجانًا ومن مصادر موثوقة، ومتاح كـ API."
  lang="ar"
  dir="rtl"
  canonicalPath="/ar"
  enPath="/"
  arPath="/ar"
  jsonLd={jsonLd}
>
  <section style="padding:var(--sp-3) 0 var(--sp-4)">
    <p class="muted" style="margin:0">الدولار النهاردة</p>
    <p class="num delta-up" style="font-size:var(--hero);margin:.1em 0;line-height:1">
      <span id="live-usd" data-live="usd">{usd ? usd.toFixed(2) : "—"}</span>
      <span class="muted" style="font-size:var(--step-1)">جنيه</span>
    </p>
    <p class="muted" style="margin:0">
      رسمي{hasParallel ? ` · الموازي ${parallelRange}` : ""} · آخر تحديث {updated}
    </p>
  </section>

  <section class="grid">
    <RateCard label="الدولار (رسمي)" value={usd} unit="جنيه" sub={hasParallel ? `الموازي ${parallelRange}` : undefined} href="/ar/usd-to-egp" detailsLabel="تفاصيل ←" />
    <RateCard label="ذهب عيار 21" value={gold21} unit="جنيه/جرام" sub="عالمي" href="/ar/gold-price-egypt" detailsLabel="تفاصيل ←" />
    <RateCard label="بنزين 92" value={gas92} unit="جنيه/لتر" sub="رسمي (هيئة البترول)" href="/ar/fuel-prices-egypt" detailsLabel="تفاصيل ←" />
    <RateCard label="الطقس · القاهرة" value={temp} unit="°م" sub="دلوقتي" href="/ar/weather/cairo" detailsLabel="تفاصيل ←" />
    <RateCard label="الفجر · القاهرة" value={fajr} sub="موعد الصلاة النهاردة" href="/ar/prayer-times/cairo" detailsLabel="تفاصيل ←" />
    <RateCard label="التاريخ الهجري" value={hijri} sub="أم القرى" href="/ar/hijri-date" detailsLabel="تفاصيل ←" />
  </section>

  <section style="padding:var(--sp-3) 0 0">
    <h2 style="font-size:var(--step-1)">الأكثر بحثاً النهاردة</h2>
    <nav class="muted" style="font-size:var(--step--1);display:flex;flex-wrap:wrap;gap:.4em var(--sp-2);margin-top:.4em">
      <a href="/ar/usd-to-egp">الدولار</a>
      <a href="/ar/black-market-dollar">الدولار السوق السودا</a>
      <a href="/ar/eur-to-egp">اليورو</a>
      <a href="/ar/sar-to-egp">الريال السعودي</a>
      <a href="/ar/aed-to-egp">الدرهم</a>
      <a href="/ar/kwd-to-egp">الدينار الكويتي</a>
      <a href="/ar/gbp-to-egp">الإسترليني</a>
      <a href="/ar/gold-18k">دهب 18</a>
      <a href="/ar/gold-price-egypt">دهب 21</a>
      <a href="/ar/gold-24k">دهب 24</a>
    </nav>
  </section>

  <section id="api" style="padding:var(--sp-5) 0 0">
    <h2 style="font-size:var(--step-2)">البيانات دي كـ API</h2>
    <p class="muted">كل رقم هنا على بُعد request واحد. مجاني، وغير تجاري.</p>
    <pre class="card num" style="overflow:auto"><code dir="ltr">curl {API_PUBLIC_BASE}/v1/fx</code></pre>
    <p class="muted" style="margin-top:var(--sp-1)">
      <a href="/docs">الـ Docs كاملة ←</a> · <a href="/status">الحالة</a>
    </p>
    <StatsStrip lang="ar" />
  </section>

  <section style="padding:var(--sp-4) 0">
    <EmailCapture lang="ar" />
  </section>

  <!-- Live updates (SSE) — same as the English home (add-live-updates). -->
  <script is:inline define:vars={{ apiBase: API_PUBLIC_BASE }}>
    (function () {
      if (!("EventSource" in window)) return;
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      function pulse() {
        if (reduce) return;
        const dot = document.querySelector(".dot");
        if (!dot) return;
        dot.classList.remove("pulse");
        void dot.offsetWidth;
        dot.classList.add("pulse");
      }
      function countUp(el, from, to) {
        // Animate old→new over ~400ms with rAF; tabular figures keep width
        // constant (no CLS). Reduced-motion or no rAF → instant swap.
        if (reduce || typeof requestAnimationFrame !== "function" || !isFinite(from)) {
          el.textContent = to.toFixed(2);
          return;
        }
        const start = performance.now();
        const dur = 400;
        function step(now) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
          el.textContent = (from + (to - from) * eased).toFixed(2);
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = to.toFixed(2);
        }
        requestAnimationFrame(step);
      }
      function apply(raw) {
        let d;
        try { d = JSON.parse(raw); } catch { return; }
        const usd = d && d.fx && d.fx.official && d.fx.official.usd;
        const el = document.getElementById("live-usd");
        if (el && typeof usd === "number") {
          const next = usd.toFixed(2);
          if (el.textContent !== next) {
            countUp(el, parseFloat(el.textContent), usd);
            pulse();
          }
        }
      }
      const es = new EventSource(apiBase + "/v1/stream");
      es.addEventListener("snapshot", (e) => apply(e.data));
      es.addEventListener("update", (e) => apply(e.data));
    })();
  </script>
</Base>
