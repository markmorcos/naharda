---
import Base from "../../layouts/Base.astro";
import { API_BASE } from "../../lib/api";

// Human-facing link + client-side fallback URL (the live, browser-reachable spec).
const SPEC_URL = "https://api.naharda.com/v1/openapi.json";

// SSR-fetch the spec and hand it to Scalar inline (`content`) so the browser
// makes NO cross-origin request — sidestepping CORS / proxy / Scalar config
// quirks that left the embed showing "Document could not be loaded". Try the
// in-cluster API first (fast), then the public URL (which is verified to serve
// the doc even if the internal image lags). If both fail, the client falls back
// to letting Scalar load the URL via its proxy.
async function fetchSpec(url: string): Promise<string | null> {
  try {
    const res = await fetch(url, {
      headers: { Accept: "application/json" },
      signal: AbortSignal.timeout(4000),
    });
    if (res.ok) return await res.text();
  } catch {
    // fail-soft: try the next source
  }
  return null;
}

const specContent =
  (await fetchSpec(`${API_BASE}/v1/openapi.json`)) ?? (await fetchSpec(SPEC_URL));
---

<Base
  title="API Reference — Naharda (interactive OpenAPI)"
  description="Interactive Naharda API reference generated from the live OpenAPI 3.1 document: browse every endpoint, see schemas and examples, and try requests against the live API."
  canonicalPath="/docs/reference"
  enPath="/docs/reference"
>
  <article style="padding:var(--sp-3) 0;max-width:46rem">
    <h1 style="font-size:var(--step-3)">API Reference</h1>
    <p class="muted">
      Generated from the live <a href={SPEC_URL}><code>/v1/openapi.json</code></a> document. Use
      the panel below to explore endpoints and try requests. Prefer prose? See the
      <a href="/docs">hand-written docs</a>.
    </p>
  </article>

  <!-- Scalar API Reference: a single CDN script, pinned so a new major can't
       break the embed. The spec is embedded inline (SSR-fetched above), so the
       browser performs no cross-origin fetch; url+proxy is only the fallback.
       `layout: classic` keeps it single-column (the modern two-pane overflows
       narrow viewports); the wrapper contains any residual horizontal overflow. -->
  <div style="max-width:100%;overflow-x:hidden">
    <div id="app"></div>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.58.0"></script>
    <script is:inline define:vars={{ specContent, SPEC_URL }}>
      Scalar.createApiReference(
        "#app",
        specContent
          ? { content: specContent, layout: "classic", theme: "default", hideDownloadButton: false }
          : { url: SPEC_URL, proxyUrl: "https://proxy.scalar.com", layout: "classic", theme: "default", hideDownloadButton: false },
      );
    </script>
  </div>
</Base>
