---
import Base from "../layouts/Base.astro";
import RateCard from "../components/RateCard.astro";
import NextPrayer from "../components/NextPrayer.astro";
import EmailCapture from "../components/EmailCapture.astro";
import StatsStrip from "../components/StatsStrip.astro";
import {
  API_PUBLIC_BASE,
  getFX,
  getGold,
  getFuel,
  getWeather,
  getPrayer,
  getCalendar,
} from "../lib/api";

const [fx, gold, fuel, weather, prayer, cal] = await Promise.all([
  getFX(),
  getGold(),
  getFuel(),
  getWeather(),
  getPrayer(),
  getCalendar(),
]);

const usd = fx?.data?.official?.usd ?? null;
const parallel = fx?.data?.parallel;
const hasParallel = !!(parallel && typeof parallel.avg === "number" && parallel.n > 0);
const parallelRange = hasParallel ? `${parallel.min}–${parallel.max}` : null;
const gold21 =
  gold?.data?.world_derived?.find((g: any) => g.karat === 21)?.value_egp ?? null;
const gas92 =
  fuel?.data?.find((f: any) => f.product === "gasoline-92")?.price_egp ?? null;
const temp = weather?.data?.weather?.temperature_c ?? null;
const prayerTimings = prayer?.data?.prayer_times?.timings ?? null;
const hijri = cal?.data?.hijri ?? null;
const updated = fx?.meta?.cached_at
  ? new Date(fx.meta.cached_at).toUTCString()
  : "unavailable";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Naharda",
  url: "https://naharda.com",
  description: "Live Egypt data: FX, gold, fuel, prayer times, weather.",
};
---

<Base
  title="Naharda — what's happening in Egypt today"
  description="Live Egyptian data in one place: the dollar today, gold prices, fuel, prayer times, weather — free, sourced, and available as a clean API."
  canonicalPath="/"
  enPath="/"
  arPath="/ar"
  jsonLd={jsonLd}
>
  <section style="padding:var(--sp-3) 0 var(--sp-4)">
    <p class="muted" style="margin:0">The dollar today</p>
    <p class="num delta-up" style="font-size:var(--hero);margin:.1em 0;line-height:1">
      <span id="live-usd" data-live="usd">{usd ? usd.toFixed(2) : "—"}</span>
      <span class="muted" style="font-size:var(--step-1)">EGP</span>
    </p>
    <p class="muted" style="margin:0">
      official{hasParallel ? ` · parallel ${parallelRange}` : ""} · updated <span id="live-updated">{updated}</span>
    </p>
  </section>

  <section class="grid">
    <RateCard label="USD → EGP (official)" value={usd} unit="EGP" sub={hasParallel ? `parallel ${parallelRange}` : undefined} href="/usd-to-egp" />
    <RateCard label="Gold 21k" value={gold21} valueId="live-gold21" unit="EGP/g" sub="world-derived" href="/gold-price-egypt" />
    <RateCard label="Gasoline 92" value={gas92} unit="EGP/L" sub="official (EGPC)" href="/fuel-prices-egypt" />
    <RateCard label="Weather · Cairo" value={temp} unit="°C" sub="now" href="/weather/cairo" />
    <NextPrayer timings={prayerTimings} lang="en" href="/prayer-times/cairo" />
    <RateCard label="Hijri date" value={hijri} sub="Umm al-Qura" href="/hijri-date" />
  </section>

  <section style="padding:var(--sp-3) 0 0">
    <h2 style="font-size:var(--step-1)">Popular today</h2>
    <nav class="muted" style="font-size:var(--step--1);display:flex;flex-wrap:wrap;gap:.4em var(--sp-2);margin-top:.4em">
      <a href="/usd-to-egp">USD → EGP</a>
      <a href="/black-market-dollar">Black-market dollar</a>
      <a href="/eur-to-egp">EUR → EGP</a>
      <a href="/sar-to-egp">SAR → EGP</a>
      <a href="/aed-to-egp">AED → EGP</a>
      <a href="/kwd-to-egp">KWD → EGP</a>
      <a href="/gbp-to-egp">GBP → EGP</a>
      <a href="/gold-18k">Gold 18k</a>
      <a href="/gold-price-egypt">Gold 21k</a>
      <a href="/gold-24k">Gold 24k</a>
    </nav>
  </section>

  <section id="api" style="padding:var(--sp-5) 0 0">
    <h2 style="font-size:var(--step-2)">This, as an API</h2>
    <p class="muted">Every number here is one clean request away. Free tier, non-commercial.</p>
    <pre class="card num" style="overflow:auto"><code>curl {API_PUBLIC_BASE}/v1/fx</code></pre>
    <p class="muted" style="margin-top:var(--sp-1)">
      <a href="/docs">Full API docs →</a> · <a href="/status">Status</a>
    </p>
    <StatsStrip lang="en" />
  </section>

  <section style="padding:var(--sp-4) 0">
    <EmailCapture lang="en" />
  </section>

  <!-- Live updates (SSE) — progressive enhancement over the SSR values (add-live-updates). -->
  <script is:inline define:vars={{ apiBase: API_PUBLIC_BASE }}>
    (function () {
      if (!("EventSource" in window)) return;
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      let es;
      function pulse() {
        if (reduce) return;
        const dot = document.querySelector(".dot");
        if (!dot) return;
        dot.classList.remove("pulse");
        void dot.offsetWidth; // restart the animation
        dot.classList.add("pulse");
      }
      function countUp(el, from, to) {
        // Animate old→new over ~400ms with rAF; tabular figures keep width
        // constant (no CLS). Reduced-motion or no rAF → instant swap.
        if (reduce || typeof requestAnimationFrame !== "function" || !isFinite(from)) {
          el.textContent = to.toFixed(2);
          return;
        }
        const start = performance.now();
        const dur = 400;
        function step(now) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
          el.textContent = (from + (to - from) * eased).toFixed(2);
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = to.toFixed(2);
        }
        requestAnimationFrame(step);
      }
      function apply(raw) {
        let d;
        try { d = JSON.parse(raw); } catch { return; }
        let changed = false;
        const usd = d && d.fx && d.fx.official && d.fx.official.usd;
        const el = document.getElementById("live-usd");
        if (el && typeof usd === "number") {
          const next = usd.toFixed(2);
          if (el.textContent !== next) {
            countUp(el, parseFloat(el.textContent), usd);
            changed = true;
          }
        }
        const gold21 = d && d.gold && Array.isArray(d.gold.world_derived)
          ? (d.gold.world_derived.find((g) => g && g.karat === 21) || {}).value_egp
          : undefined;
        const gEl = document.getElementById("live-gold21");
        if (gEl && typeof gold21 === "number") {
          const next = gold21.toLocaleString(undefined, { maximumFractionDigits: 2 });
          if (gEl.textContent !== next) {
            gEl.textContent = next;
            changed = true;
          }
        }
        const upEl = document.getElementById("live-updated");
        if (upEl && d && d.ts) {
          const next = new Date(d.ts).toUTCString();
          if (upEl.textContent !== next) upEl.textContent = next;
        }
        if (changed) pulse();
      }
      function connect() {
        es = new EventSource(apiBase + "/v1/stream");
        es.addEventListener("snapshot", (e) => apply(e.data));
        es.addEventListener("update", (e) => apply(e.data));
        // EventSource auto-reconnects on error; nothing else needed.
      }
      connect();
    })();
  </script>
</Base>
