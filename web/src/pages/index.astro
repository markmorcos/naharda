---
import Base from "../layouts/Base.astro";
import RateCard from "../components/RateCard.astro";
import EmailCapture from "../components/EmailCapture.astro";
import {
  API_PUBLIC_BASE,
  getFX,
  getGold,
  getFuel,
  getWeather,
  getPrayer,
  getCalendar,
} from "../lib/api";

const [fx, gold, fuel, weather, prayer, cal] = await Promise.all([
  getFX(),
  getGold(),
  getFuel(),
  getWeather(),
  getPrayer(),
  getCalendar(),
]);

const usd = fx?.data?.official?.usd ?? null;
const parallel = fx?.data?.parallel;
const hasParallel = !!(parallel && typeof parallel.avg === "number" && parallel.n > 0);
const parallelRange = hasParallel ? `${parallel.min}–${parallel.max}` : null;
const gold21 =
  gold?.data?.world_derived?.find((g: any) => g.karat === 21)?.value_egp ?? null;
const gas92 =
  fuel?.data?.find((f: any) => f.product === "gasoline-92")?.price_egp ?? null;
const temp = weather?.data?.weather?.temperature_c ?? null;
const fajr = prayer?.data?.prayer_times?.timings?.Fajr ?? null;
const hijri = cal?.data?.hijri ?? null;
const updated = fx?.meta?.cached_at
  ? new Date(fx.meta.cached_at).toUTCString()
  : "unavailable";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Naharda",
  url: "https://naharda.com",
  description: "Live Egypt data: FX, gold, fuel, prayer times, weather.",
};
---

<Base
  title="Naharda — what's happening in Egypt today"
  description="Live Egyptian data in one place: the dollar today, gold prices, fuel, prayer times, weather — free, sourced, and available as a clean API."
  canonicalPath="/"
  enPath="/"
  arPath="/ar"
  jsonLd={jsonLd}
>
  <section style="padding:var(--sp-3) 0 var(--sp-4)">
    <p class="muted" style="margin:0">The dollar today</p>
    <p class="num delta-up" style="font-size:var(--hero);margin:.1em 0;line-height:1">
      <span id="live-usd" data-live="usd">{usd ? usd.toFixed(2) : "—"}</span>
      <span class="muted" style="font-size:var(--step-1)">EGP</span>
    </p>
    <p class="muted" style="margin:0">
      official{hasParallel ? ` · parallel ${parallelRange}` : ""} · updated {updated}
    </p>
  </section>

  <section class="grid">
    <RateCard label="USD → EGP (official)" value={usd} unit="EGP" sub={hasParallel ? `parallel ${parallelRange}` : undefined} href="/usd-to-egp" />
    <RateCard label="Gold 21k" value={gold21} unit="EGP/g" sub="world-derived" href="/gold-price-egypt" />
    <RateCard label="Gasoline 92" value={gas92} unit="EGP/L" sub="official (EGPC)" href="/fuel-prices-egypt" />
    <RateCard label="Weather · Cairo" value={temp} unit="°C" sub="now" href="/weather/cairo" />
    <RateCard label="Fajr · Cairo" value={fajr} sub="prayer time today" href="/prayer-times/cairo" />
    <RateCard label="Hijri date" value={hijri} sub="Umm al-Qura" href="/hijri-date" />
  </section>

  <section id="api" style="padding:var(--sp-5) 0 0">
    <h2 style="font-size:var(--step-2)">This, as an API</h2>
    <p class="muted">Every number here is one clean request away. Free tier, non-commercial.</p>
    <pre class="card num" style="overflow:auto"><code>curl {API_PUBLIC_BASE}/v1/fx</code></pre>
    <p class="muted" style="margin-top:var(--sp-1)">
      <a href="/docs">Full API docs →</a> · <a href="/status">Status</a>
    </p>
  </section>

  <section style="padding:var(--sp-4) 0">
    <EmailCapture lang="en" />
  </section>

  <!-- Live updates (SSE) — progressive enhancement over the SSR values (add-live-updates). -->
  <script is:inline define:vars={{ apiBase: API_PUBLIC_BASE }}>
    (function () {
      if (!("EventSource" in window)) return;
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      let es;
      function pulse() {
        if (reduce) return;
        const dot = document.querySelector(".dot");
        if (!dot) return;
        dot.classList.remove("pulse");
        void dot.offsetWidth; // restart the animation
        dot.classList.add("pulse");
      }
      function apply(raw) {
        let d;
        try { d = JSON.parse(raw); } catch { return; }
        const usd = d && d.fx && d.fx.official && d.fx.official.usd;
        const el = document.getElementById("live-usd");
        if (el && typeof usd === "number") {
          const next = usd.toFixed(2);
          if (el.textContent !== next) { el.textContent = next; pulse(); }
        }
      }
      function connect() {
        es = new EventSource(apiBase + "/v1/stream");
        es.addEventListener("snapshot", (e) => apply(e.data));
        es.addEventListener("update", (e) => apply(e.data));
        // EventSource auto-reconnects on error; nothing else needed.
      }
      connect();
    })();
  </script>
</Base>
